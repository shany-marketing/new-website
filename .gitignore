# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit secrets
.env
.env.local
.env.production
.env.staging

# terraform secrets
terraform/.terraform/
terraform/terraform.tfstate
terraform/terraform.tfstate.backup
terraform/.terraform.lock.hcl
terraform/terraform.tfvars

# vercel
.vercel

# reference notebooks (contain API keys)
stage_*.txt

# archives / temp
guest-insight-pro.zip
guest-insight-pro/
tmp/
NUL

# source assets (served copies are in public/)
/assets/

# credentials
CREDENTIALS.md

# claude code (may contain secrets in tool permissions)
.claude/

# database dumps (contain password hashes)
*.sql
!migrations/*.sql

# data exports
*.csv

# typescript
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────
#  UpStar – Environment Variables Template
#  Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://upstar_admin:PASSWORD@RDS_ENDPOINT:5432/upstar

# ── AWS ───────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/upstar-pipeline-prod.fifo

# ── AI APIs ───────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=
PERPLEXITY_API_KEY=

# ── Apify ─────────────────────────────────────
APIFY_API_TOKEN=
APIFY_ACTOR_ID=

# ── Auth (NextAuth) ───────────────────────────
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
